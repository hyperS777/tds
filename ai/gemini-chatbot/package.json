{
  "name": "gemini-chatbot-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && venv\\Scripts\\python.exe main.py",
    "install:all": "cd frontend && npm install && cd ../backend && venv\\Scripts\\pip.exe install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
